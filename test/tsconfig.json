{
  "compilerOptions": {
    "target": "ES2023",
    "module": "NodeNext",
    "moduleResolution": "node16",
    "lib": ["esnext"],
    "types": ["node"],
    "typeRoots": ["../node_modules/@types", "../src/@types"],
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": ["./**/*.ts", "./types/**/*.d.ts", "../src/**/*.ts", "../src/@types/**/*.d.ts"],
  "exclude": ["../dist", "../node_modules"]
}
