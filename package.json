{
  "name": "tuber-server",
  "version": "0.1.0",
  "packageManager": "yarn@3.2.4",
  "scripts": {
    "watch": "tsc --watch --preserveWatchOutput --pretty",
    "dev": "cross-env NODE_ENV=development nodemon",
    "format": "prettier --write \"src/**/*.ts\"",
    "build": "rimraf dist && tsc && tsc-alias",
    "start": "NODE_ENV=production node dist/index.js",
    "deploy:ec2": "powershell -ExecutionPolicy Bypass -File ./deploy-ec2.ps1"
  },
  "dependencies": {
    "@fastify/cookie": "^9.0.4",
    "@fastify/cors": "^8.3.0",
    "@fastify/csrf": "^6.3.0",
    "@fastify/jwt": "^7.2.4",
    "@fastify/secure-session": "^6.2.0",
    "@fastify/session": "^10.4.0",
    "@fastify/static": "^7.0.0",
    "@types/dotenv": "^8.2.0",
    "axios": "^1.6.2",
    "bcrypt": "^5.1.0",
    "csv-parse": "^5.5.6",
    "dotenv": "^16.3.1",
    "fastify": "^4.19.0",
    "hogan.js": "^3.0.2",
    "js-yaml": "^4.1.0",
    "mongoose": "^8.0.2",
    "mongoose-paginate-v2": "^1.7.4",
    "node-cache": "^5.1.2",
    "node-cron": "^3.0.3",
    "urllib": "^3.19.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.0",
    "@types/hogan.js": "^3.0.1",
    "@types/jest": "^29.5.4",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.3.3",
    "@types/node-cron": "^3.0.11",
    "cross-env": "^7.0.3",
    "fastify-tsconfig": "^1.0.1",
    "jest": "^29.6.4",
    "nodemon": "^2.0.22",
    "prettier": "^2.8.8",
    "rimraf": "^5.0.1",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.6"
  }
}
