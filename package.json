{
  "name": "tuber-server",
  "version": "0.1.0-alpha",
  "description": "This project was bootstrapped with Fastify-CLI.",
  "main": "app.ts",
  "directories": {
    "test": "test"
  },
  "scripts": {
    "test": "npm run build:ts && tsc -p test/tsconfig.json && c8 node --test -r ts-node/register \"test/**/*.ts\"",
    "start": "npm run build:ts && fastify start -l info dist/app.js | pino-pretty",
    "build:ts": "tsc",
    "build:client": "cd ../tuber-client && pnpm install && pnpm run build && cd ../tuber-server && rimraf client && node -e \"require('fs').cpSync('../tuber-client/dist','./client',{recursive:true})\"",
    "build:fullstack": "pnpm run build:client && pnpm run build:ts",
    "watch:ts": "tsc -w",
    "dev": "npm run build:ts && concurrently -k -p \"[{name}]\" -n \"TypeScript,App\" -c \"yellow.bold,cyan.bold\" \"npm:watch:ts\" \"npm:dev:start\"",
    "dev:start": "fastify start --ignore-watch=.ts$ -w -l info -P dist/app.js | pino-pretty",
    "clean": "rimraf dist",
    "migrate:users-collation": "ts-node src/install/ensure.users.collation.ts",
    "bench:bookmarks": "node scripts/load-test-bookmarks.mjs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@fastify/autoload": "^6.0.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.1.0",
    "@fastify/jwt": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/sensible": "^6.0.0",
    "@fastify/static": "^8.3.0",
    "@tuber/shared": "file:../tuber-shared",
    "axios": "^1.13.2",
    "bcrypt": "^6.0.0",
    "csv-parse": "^6.1.0",
    "dotenv": "^17.2.3",
    "fastify": "^5.0.0",
    "fastify-cli": "^7.4.1",
    "fastify-plugin": "^5.0.0",
    "js-yaml": "^4.1.0",
    "mongoose": "^8.19.3",
    "mongoose-paginate-v2": "^1.9.1",
    "node-cache": "^5.1.2",
    "node-cron": "^4.2.1",
    "nodemailer": "^6.9.11",
    "qs": "^6.14.0",
    "urllib": "^4.8.2",
    "winston": "^3.18.3"
  },
  "devDependencies": {
    "@mui/material": "^7.3.5",
    "@types/bcrypt": "^6.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.0.8",
    "@types/nodemailer": "^7.0.4",
    "@types/qs": "^6.14.0",
    "@types/react": "^19.2.2",
    "c8": "^10.1.2",
    "concurrently": "^9.0.0",
    "fastify-tsconfig": "^3.0.0",
    "pino-pretty": "^13.1.2",
    "react": "^19.2.0",
    "rimraf": "^6.1.0",
    "ts-node": "^10.4.0",
    "typescript": "~5.9.2"
  },
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be"
}
